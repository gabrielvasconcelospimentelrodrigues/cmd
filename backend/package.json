{
  "name": "cmd-saas-backend",
  "version": "0.1.0",
  "private": true,
  "description": "CMD SaaS — API Fastify (assíncrona, leve, alta concorrência)",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
