    "@fastify/multipart": "^10.0.0",
    "@supabase/supabase-js": "^2.45.4",
    "bullmq": "^5.79.2",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "fastify-plugin": "^6.0.0",
    "fernet": "^0.3.3",
    "ioredis": "^5.4.1",
    "pg": "^8.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
