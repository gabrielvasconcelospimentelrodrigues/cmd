# =============================================================================
# CMD SaaS — Backend (Fastify) — TEMPLATE de ambiente
# Copie para `.env` e preencha. NÃO coloque segredos reais aqui.
# =============================================================================

NODE_ENV=development
PORT=3333

# --- Supabase ----------------------------------------------------------------
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Postgres ----------------------------------------------------------------
DATABASE_URL=postgresql://postgres.SEU-PROJETO:[YOUR-PASSWORD]@aws-0-REGIAO.pooler.supabase.com:6543/postgres

# --- Redis (BullMQ) ----------------------------------------------------------
REDIS_URL=redis://localhost:6379

# --- Segurança ---------------------------------------------------------------
FIELD_ENCRYPTION_KEY=
CORS_ORIGINS=http://localhost:5173
